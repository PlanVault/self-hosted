# PlanVault self-hosted configuration contract (.env.example)
# Copy to .env via scripts/generate-secrets.sh — never commit .env or real secrets.

# -----------------------------------------------------------------------------
# Release / registry (required)
# -----------------------------------------------------------------------------
# Public GHCR registry — no docker login required.
PLANVAULT_REGISTRY=ghcr.io/planvault
# Pinned image tag for api, jobs, and edge (never use `latest` for supported deployments).
# Match this repo's VERSION file (or the git tag you checked out) before docker compose pull.
PLANVAULT_VERSION=0.1.5

# -----------------------------------------------------------------------------
# License (required)
# -----------------------------------------------------------------------------
# Vendor-signed offline license JWT — supplied by PlanVault out-of-band (never commit a real token).
PLANVAULT_LICENSE_KEY=__INVALID_LICENSE_JWT__

# -----------------------------------------------------------------------------
# Public URLs / CORS (required after install)
# -----------------------------------------------------------------------------
# Local quick-start origin of the dashboard and API (no trailing slash).
# Change to your real HTTPS origin before exposing the stack outside localhost.
BASE_URL=http://localhost
# Hostname only (no scheme/path), used in documentation and optional integrations.
PUBLIC_DOMAIN=localhost
# Comma-separated browser origins allowed by the API (must include BASE_URL).
CORS_ORIGINS=http://localhost,http://127.0.0.1
# Keycloak public hostname URL (scheme + host + /keycloak path).
KC_PUBLIC_HOSTNAME=http://localhost/keycloak
# Public OIDC issuer in tokens. Must match KC_PUBLIC_HOSTNAME + /realms/planvault.
KEYCLOAK_ISSUER=http://localhost/keycloak/realms/planvault

# -----------------------------------------------------------------------------
# Encryption / key material (required — use scripts/generate-secrets.sh)
# -----------------------------------------------------------------------------
# Cleartext Tink JSON keyset for the local KEK (SELF_HOSTED). Replaced by generate-secrets.sh.
TINK_LOCAL_KEYSET_JSON=__GENERATE__
# Base64-encoded HMAC key (≥32 decoded bytes) for external user id pseudonymization.
SECURITY_HMAC_KEY=__GENERATE__
# Separate HMAC key for tenant-safe trace/log/metric labels.
OBSERVABILITY_TENANT_HMAC_KEY=__GENERATE__

# -----------------------------------------------------------------------------
# PostgreSQL (required — use scripts/generate-secrets.sh)
# -----------------------------------------------------------------------------
DB_USER_SUPERUSER=planvault_super
DB_PASSWORD_SUPERUSER=__GENERATE__
DB_USER_API=planvault_api
DB_PASSWORD_API=__GENERATE__
DB_USER_KC=planvault_kc
DB_PASSWORD_KC=__GENERATE__
DB_USER_LITELLM=planvault_litellm
DB_PASSWORD_LITELLM=__GENERATE__
POSTGRES_MAX_CONNECTIONS=150
DB_POOL_SIZE=10
DB_POOL_SIZE_JOBS=4

# -----------------------------------------------------------------------------
# Redis (required — use scripts/generate-secrets.sh)
# -----------------------------------------------------------------------------
REDIS_PASSWORD=__GENERATE__

# -----------------------------------------------------------------------------
# Keycloak (required — use scripts/generate-secrets.sh)
# -----------------------------------------------------------------------------
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=__GENERATE__
KEYCLOAK_ADMIN_CLIENT_ID=planvault-api
KEYCLOAK_ADMIN_CLIENT_SECRET=__GENERATE__
KEYCLOAK_AZP_PRIMARY=planvault-front
KEYCLOAK_SKIP_ACCESS_TOKEN_AUDIENCE_ISSUER_CHECKS=false

# -----------------------------------------------------------------------------
# LiteLLM (required — use scripts/generate-secrets.sh)
# -----------------------------------------------------------------------------
LITELLM_MASTER_KEY=__GENERATE__

# -----------------------------------------------------------------------------
# BYOK / LLM providers (optional — org-level keys are preferred; infra keys are optional)
# -----------------------------------------------------------------------------
# OPENAI_API_KEY=__INVALID_OPENAI_KEY__
# ANTHROPIC_API_KEY=__INVALID_ANTHROPIC_KEY__
# GEMINI_API_KEY=__INVALID_GEMINI_KEY__

# -----------------------------------------------------------------------------
# Default billing plan for new organizations (optional)
# -----------------------------------------------------------------------------
# Omitted limit variables mean unlimited (NULL in DB). Synced on every api/jobs startup.
# PLANVAULT_DEFAULT_FREE_PLAN_SLUG=free
# PLANVAULT_DEFAULT_FREE_PLAN_NAME=Free
# PLANVAULT_DEFAULT_FREE_PLAN_MAX_ORGS_AS_OWNER=1
# PLANVAULT_DEFAULT_FREE_PLAN_MAX_PROJECTS_PER_ORG=2
# PLANVAULT_DEFAULT_FREE_PLAN_MAX_MEMBERS_PER_ORG=5
# PLANVAULT_DEFAULT_FREE_PLAN_MAX_TOKENS=1000000
# PLANVAULT_DEFAULT_FREE_PLAN_MAX_AUTO_SCENARIOS=10

# -----------------------------------------------------------------------------
# Retention (optional)
# -----------------------------------------------------------------------------
SESSION_RETENTION_DAYS=90
SESSION_RETENTION_MIN_DAYS=1
SESSION_RETENTION_MAX_DAYS=1461
AUDIT_RETENTION_DAYS=365
AUDIT_RETENTION_MIN_DAYS=0
AUDIT_RETENTION_MAX_DAYS=3650
PLANVAULT_ORG_SOFT_DELETE_GRACE_DAYS=7
PLANVAULT_ORG_SOFT_DELETE_SWEEPER_INTERVAL_HOURS=24

# -----------------------------------------------------------------------------
# OpenTelemetry baseline (API — packaging/onprem/observability/)
# -----------------------------------------------------------------------------
# OTEL_JAVAAGENT_ENABLED=false
# OTEL_SERVICE_NAME=planvault-api
# OTEL_EXPORTER_OTLP_ENDPOINT=https://otel-collector:4317
# OTEL_EXPORTER_OTLP_PROTOCOL=grpc
# OTEL_CERTS_HOST_DIR=./observability/certs
# OTEL_EXPORTER_OTLP_CLIENT_CERTIFICATE=/certs/client.crt
# OTEL_EXPORTER_OTLP_CLIENT_KEY=/certs/client.key
# OTEL_EXPORTER_OTLP_CERTIFICATE=/certs/ca.crt
# Dev mTLS: ../../infra/observability/certs/generate-dev-certs.sh (or copy into ./observability/certs)

# -----------------------------------------------------------------------------
# Observability overlay (optional — docs/runbook/observability.md)
# -----------------------------------------------------------------------------
# GRAFANA_ADMIN_PASSWORD=__GENERATE__
# GRAFANA_PORT=3000
# PROMETHEUS_ENV=onprem
# PROMETHEUS_CONFIG_FILE=./observability/prometheus/prometheus.yml
# Grafana Keycloak OIDC (confidential client; redirect http://127.0.0.1:3000/login/generic_oauth):
# GRAFANA_OIDC_CLIENT_ID=planvault-grafana
# GRAFANA_OIDC_CLIENT_SECRET=__GENERATE__
# GRAFANA_OIDC_AUTH_URL=http://localhost/keycloak/realms/planvault/protocol/openid-connect/auth
# GRAFANA_OIDC_TOKEN_URL=http://localhost/keycloak/realms/planvault/protocol/openid-connect/token
# GRAFANA_OIDC_API_URL=http://localhost/keycloak/realms/planvault/protocol/openid-connect/userinfo
# GRAFANA_OIDC_SIGNOUT_REDIRECT_URL=http://localhost/keycloak/realms/planvault/protocol/openid-connect/logout
# Loki object storage (local/dev default filesystem; prod use standalone MinIO/S3-compatible or AWS S3):
# LOKI_OBJECT_STORE=s3
# LOKI_DELETE_REQUEST_STORE=s3
# LOKI_S3_BUCKET=planvault-loki
# LOKI_S3_ENDPOINT=minio:9000
# LOKI_S3_REGION=us-east-1
# LOKI_S3_ACCESS_KEY_ID=__INVALID__
# LOKI_S3_SECRET_ACCESS_KEY=__INVALID__
# LOKI_S3_INSECURE=true
# LOKI_S3_FORCE_PATH_STYLE=true
# Tempo object storage (local/dev default TEMPO_STORAGE_BACKEND=local):
# TEMPO_STORAGE_BACKEND=s3
# TEMPO_S3_BUCKET=planvault-tempo
# TEMPO_S3_ENDPOINT=minio:9000
# TEMPO_S3_REGION=us-east-1
# TEMPO_S3_ACCESS_KEY=__INVALID__
# TEMPO_S3_SECRET_KEY=__INVALID__
# TEMPO_S3_INSECURE=true
# TEMPO_S3_FORCE_PATH_STYLE=true
# OTel collector peak mode: edit observability/otel-collector/otel-col.yaml to insert probabilistic_sampler/peak_*
# after filter/drop_unscoped_* and before batch, then reload/redeploy otel-collector.
# docker compose --env-file .env -f docker-compose.yml -f docker-compose.observability.yml \
#   --profile with_redis_exporter --profile with_postgres_exporter up -d
# OTEL_LOGS_EXPORTER=otlp
# OTEL_INSTRUMENTATION_LOGBACK_APPENDER_EXPERIMENTAL_CAPTURE_ALL_MDC_ATTRIBUTES=true
# Traces/logs: enable OTEL_JAVAAGENT_ENABLED, OTEL_EXPORTER_OTLP_PROTOCOL=grpc, and mTLS certs; overlay adds otel-collector + Tempo + Loki.
# Minimal scrape without local Redis/Postgres exporters:
# PROMETHEUS_CONFIG_FILE=./observability/prometheus/prometheus.minimal.yml \
#   docker compose --env-file .env -f docker-compose.yml -f docker-compose.observability.yml up -d

# -----------------------------------------------------------------------------
# Edge ports / TLS (optional)
# -----------------------------------------------------------------------------
HTTP_PORT=80
# HTTPS_PORT=443
# Enable direct TLS on edge after placing certs under ./tls/ and starting profile direct_tls:
#   docker compose --profile direct_tls up -d
# Managed HTTPS via docker-compose.caddy.yml (optional):
# Set HTTP_PORT=8080 before enabling this overlay so Caddy can bind host port 80.
# CADDY_SITE_ADDRESS=https://planvault.example.com
# CADDY_HTTP_PORT=80
# CADDY_HTTPS_PORT=443
